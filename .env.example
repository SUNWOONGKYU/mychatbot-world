# ============================================
# MCW (My Chatbot World) — 환경 변수 템플릿
# ============================================
# 이 파일을 .env.local로 복사하고 실제 값을 입력하세요.
# .env.local은 .gitignore에 포함되어 커밋되지 않습니다.

# ── Supabase (필수) ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI API (필수 — 최소 하나) ────────────────
OPENROUTER_API_KEY=your-openrouter-key
OPENAI_API_KEY=your-openai-key

# ── 인증 ─────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000

# ── 관리자 ───────────────────────────────────
ADMIN_API_KEY=your-admin-api-key

# ── 결제 (무통장 입금 계좌) ──────────────────
PAYMENT_BANK_NAME=하나은행
PAYMENT_ACCOUNT_NUMBER=287-910921-40507
PAYMENT_ACCOUNT_HOLDER=파인더월드

# ── 이메일 (선택) ────────────────────────────
# RESEND_API_KEY=your-resend-key

# ── Upstash Redis (Rate Limiting) ────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── CPC 시스템 (선택, 소대 운영 시) ──────────
# CPC_SUPABASE_URL=https://cpc-project.supabase.co
# CPC_SUPABASE_KEY=your-cpc-key
