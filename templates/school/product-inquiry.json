{
  "scenarioId": "product-inquiry",
  "scenarioName": "상품/서비스 문의 응대",
  "description": "고객의 상품 및 서비스 문의에 명확하고 친절하게 답변하는 법을 학습합니다.",
  "xpReward": 10,
  "steps": [
    {
      "stepId": 1,
      "userPrompt": "이 제품이 정확히 어떤 기능을 하는 건가요?",
