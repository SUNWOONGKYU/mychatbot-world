    },
    {
      "stepId": 2,
      "userPrompt": "가격은 얼마인가요? 다른 옵션도 있나요?",
      "expectedTopics": ["가격 안내", "옵션", "플랜 비교"]
    },
    {
      "stepId": 3,
      "userPrompt": "비슷한 다른 제품과 비교하면 어떤 장점이 있나요?",
