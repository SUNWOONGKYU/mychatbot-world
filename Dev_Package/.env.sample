# ============================================
# SAL Grid Dev Suite - Environment Variables
# ============================================
# 이 파일을 .env로 복사하고 실제 값을 입력하세요.
# .env 파일은 절대 커밋하지 마세요! (.gitignore에 포함됨)

# ============================================
# Supabase (프로젝트 DB)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# 프로젝트 정보
# ============================================
PROJECT_ID=your-project-id
OWNER_EMAIL=your-email@example.com

# ============================================
# 선택 설정
# ============================================
DEBUG_MODE=false

# ============================================
# [참고] SSAL Works 플랫폼 연동 (선택사항)
# ============================================
# SSAL Works 플랫폼(ssalworks.ai.kr)과 연동 시에만 설정
# 연동 방법: Claude Code에 "Viewer 연결해줘" 요청
#
# SSAL_WORKS_SUPABASE_URL=https://[ssal-works-project].supabase.co
# SSAL_WORKS_ANON_KEY=your-ssal-works-anon-key
# AUTO_UPLOAD_PROGRESS=false
